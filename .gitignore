# ==========================================
# GitIgnore for GateOS Monorepo
# ==========================================

# Dependency directories
node_modules/
.pnpm-store/

# Build & Compilation Outputs
dist/
dist-ssr/
build/
**/target/
**/*.class
**/*.jar
**/*.war
**/*.ear
**/*.nar

# Turborepo
.turbo/
**/.turbo/

# Environment & Secrets (CRITICAL)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*.local
keys/
*.pem
*.key
*.p12

# IDEs & Editor configurations
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml
*.ipr
*.iws

# Logs & Diagnostics
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.exec

# OS Files
.DS_Store
Thumbs.db

# AI Agents
.agents/
skills-lock.json

# Local Auth Cache
login_response.json

# AI Prompts
promt.md